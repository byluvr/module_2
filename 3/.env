# HQ-SRV address reachable from HQ-CLI.
NFS_SERVER_IP=192.168.1.10

# Only this client-side network may use the export.
HQ_CLI_SUBNET=192.168.2.0/28

NFS_EXPORT_PATH=/raid/nfs
NFS_CLIENT_MOUNT=/mnt/nfs

# Server and client parameters.
NFS_EXPORT_OPTIONS=rw,sync,no_subtree_check,no_root_squash
NFS_MOUNT_OPTIONS=defaults,_netdev

# File created by the client to verify read/write access.
NFS_TEST_FILE=test.txt

