# Common domain settings
DOMAIN_FQDN=au-team.irpo
DOMAIN_NETBIOS=AU-TEAM
DOMAIN_ADMIN_USER=Administrator

# BR-SRV
DC_HOSTNAME=br-srv
BR_SRV_IP=192.168.3.10
BR_SRV_INTERFACE=enp7s1
DNS_FORWARDER=192.168.1.10
DOMAIN_ADMIN_PASSWORD=P@ssw0rd

# DNS records hosted by Samba.
HQ_SRV_IP=192.168.1.10
HQ_CLI_IP=192.168.2.10
HQ_RTR_IP=192.168.1.1
BR_RTR_IP=192.168.3.1
ISP_HQ_IP=172.16.1.1
MON_HOSTNAME=mon
WEB_HOSTNAME=web
DOCKER_HOSTNAME=docker

# Domain users
HQ_GROUP=hq
HQ_USER_PREFIX=hquser
HQ_USER_COUNT=5
HQ_USER_PASSWORD=P@ssw0rd

# HQ-CLI
HQ_CLI_HOSTNAME=hq-cli
HQ_CLI_INTERFACE=enp7s1

# Set to yes only when an existing Samba domain must be deleted and rebuilt.
RESET_SAMBA=no
