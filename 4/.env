# Upstream selected by the participant.
UPSTREAM_NTP=ntp0.ntp-servers.net

# Stratum advertised by ISP. Valid chrony local stratum: 1..15.
LOCAL_STRATUM=5

# Networks allowed to use ISP as an NTP server.
NTP_ALLOW_NETWORK=0.0.0.0/0

# ISP interface addresses toward each site.
ISP_HQ_IP=172.16.1.1
ISP_BR_IP=172.16.2.1

# auto: hq-* clients use ISP_HQ_IP, br-* clients use ISP_BR_IP.
# Set an IP here only when the hostname does not follow that convention.
NTP_SERVER_IP_OVERRIDE=

