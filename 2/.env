# RAID device name: md0, md1, etc. The /dev/ prefix is optional.
RAID_NAME=md0

# Supported levels: 0, 1, 5.
RAID_LEVEL=0

# Filled automatically by ./00-list-disks.sh.
RAID_DISKS=""

EXPECTED_DISK_SIZE_GIB=1
CREATE_PARTITION=yes
MOUNT_POINT=/raid
FILESYSTEM=ext4

# Set to yes to allow initial creation or rebuilding after RAID settings change.
ERASE_DISKS=yes
