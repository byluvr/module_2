# RAID device name: md0, md1, etc. The /dev/ prefix is optional.
RAID_NAME=md0

# Supported levels: 0, 1, 5.
RAID_LEVEL=0

# Explicit list of disks whose data may be destroyed.
RAID_DISKS="/dev/sdb /dev/sdc"

# The task specifies 1 GiB disks. Set to 0 to disable the size check.
EXPECTED_DISK_SIZE_GIB=1

# yes: create /dev/md0p1 and format it.
# no: create ext4 directly on /dev/md0, as in some methodical guides.
CREATE_PARTITION=yes

MOUNT_POINT=/raid
FILESYSTEM=ext4

# Mandatory protection against accidental disk erasure.
ERASE_DISKS=no

