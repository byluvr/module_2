# Addresses will be adjusted after the final topology is known.
HQ_SRV_IP=192.168.1.10
HQ_CLI_IP=192.168.2.10
HQ_RTR_IP=172.16.0.1
BR_RTR_IP=192.168.3.1

# ALT Linux managed hosts.
LINUX_SSH_USER=sshuser
LINUX_SSH_PASSWORD=P@ssw0rd
LINUX_SSH_PORT=2026
SSH_ALLOW_USERS="sshuser"
SSH_MAX_AUTH_TRIES=2

# EcoRouter managed hosts.
ROUTER_SSH_USER=net_admin
ROUTER_SSH_PASSWORD=P@ssw0rd
ROUTER_SSH_PORT=22

# Controller key on BR-SRV.
ANSIBLE_SSH_KEY=/root/.ssh/id_rsa

