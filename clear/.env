# Remove the local copy of module_2 after deleting generated artifacts.
DELETE_PROJECT=yes

# Unmount Additional.iso when it is mounted at /mnt.
UNMOUNT_ADDITIONAL_ISO=no
ISO_MOUNT=/mnt

# Remove the NFS write-test file created by task 3.
REMOVE_NFS_TEST_FILE=no
NFS_CLIENT_MOUNT=/mnt/nfs
NFS_TEST_FILE=test.txt
